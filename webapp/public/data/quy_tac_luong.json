  "calculation_rules": {
    "get_salary_coefficient": "salary_tables[salary_group].coefficients[String(salary_grade)]",
    "get_regular_raise_months": "Find first salary_increase_policy where effective_month in period and rule matches subject_type, salary_group, salary_coefficient.",
    "next_grade": "salary_grade < max_grade ? salary_grade + 1 : null",
    "next_raise_month": "add_months(salary_start_month, regular_raise_months - early_salary_months + delay_months)",
    "salary_amount": "salary_coefficient * base_salary_amount",
    "get_officer_rank_coefficient": "salary_tables[salary_group].coefficients[String(salary_grade || 1)] where subject_type == \"SQ\"",
    "get_next_officer_rank_month": "Find rank_promotion_policy.rules where from_rank_code == salary_group; add months/months_min to rank_start_month; only show as expected review date.",
    "officer_grade_meaning": "For SQ: salary_grade 1 = rank coefficient; 2 = officer salary raise lần 1; 3 = officer salary raise lần 2."
  },
  "programming_notes": [
    "Trong UI, trường salary_group nên lưu code bảng lương như VC_A1, VC_A3_N1, QNCN_CC_N1 để tra hệ số nhanh.",
